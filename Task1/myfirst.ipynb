     "output_type": "stream",
     "text": [
      "Enter the apparent magnitude:  8\n",
      "Enter the absolute magnitude:  3\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "The value of the distance modulus is 326.164 lightyears\n"
     ]
    }
   ],
   "source": [
    "m = input(\"Enter the apparent magnitude: \")\n",
    "M = input(\"Enter the absolute magnitude: \") \n",
    "\n",
    "m2= float(m)\n",
    "M2= float(M)\n",
    "\n",
    "d = 10.0 * pow( 10.0, (m2-M2)/5.0 ) * 3.26164\n",
    "\n",
    "s=f\"The value of the distance modulus is {d} lightyears\"\n",
    "\n",
    "print(s)\n",
    "\n"
   ]
