   "source": [
    "Y = int(input(\"The year is: \"))\n",
    "M = int(input(\"The month is: \"))\n",
    "D = float(input(\"The day is: \"))\n",
    "\n",
    "JD = 367*Y -7*(Y+(M+9)//12)//4 - 3*((Y+(M-9)//7)//100 + 1)//4 + (275*M)//9 + D + 1721029-0.5\n",
    "\n",
    "print(f\"The Julian Date is {JD}\")"
   ]
  }
 ],
